{
  "name": "nexora",
  "version": "0.1.0",
  "private": true,
  "description": "Nexora — AI Business Operating System for SMBs",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:api": "npm run dev --workspace @nexora/api",
    "dev:web": "npm run dev --workspace @nexora/web",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:reset": "docker compose down -v && docker compose up -d",
    "db:migrate": "npm run db:migrate --workspace @nexora/api",
    "db:seed": "npm run db:seed --workspace @nexora/api",
    "db:studio": "npm run db:studio --workspace @nexora/api",
    "setup": "npm install && npm run infra:up && npm run db:migrate && npm run db:seed"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "trailingComma": "all",
    "printWidth": 100
  }
}
