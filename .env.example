# ---------------------------------------------------------------------------
# Nexora environment configuration
# Copy to `.env` and fill in real values. Never commit `.env`.
# ---------------------------------------------------------------------------

NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000

# --- Database -------------------------------------------------------------
DATABASE_URL=postgresql://nexora:nexora@localhost:5432/nexora?schema=public

# --- Cache / Queue --------------------------------------------------------
REDIS_URL=redis://localhost:6379

# --- Auth -----------------------------------------------------------------
# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=replace-me-with-a-long-random-string
JWT_REFRESH_SECRET=replace-me-with-a-different-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- OAuth (optional in development) --------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# --- AI providers ---------------------------------------------------------
# The AI layer is provider-agnostic. Set AI_DEFAULT_PROVIDER to whichever you
# have a key for; unconfigured providers are simply not registered at boot.
AI_DEFAULT_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Billing (Razorpay) ----------------------------------------------------
# Optional: the 14-day trial takes no card, so the whole platform runs without
# these. You only need them to accept paid subscriptions.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Plan ids from the Razorpay dashboard (one per purchasable tier)
RAZORPAY_PLAN_STARTER=
RAZORPAY_PLAN_GROWTH=
RAZORPAY_PLAN_ENTERPRISE=

# --- Object storage (S3 compatible; MinIO in local dev) -------------------
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=nexora
S3_ACCESS_KEY_ID=nexora
S3_SECRET_ACCESS_KEY=nexora-secret
S3_FORCE_PATH_STYLE=true

# --- Web app (Next.js public vars) ---------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000
